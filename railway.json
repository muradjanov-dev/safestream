{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "buildCommand": "pnpm install --no-frozen-lockfile && pnpm --filter @safestream/web build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @safestream/web start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
